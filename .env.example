# AgentForge — environment template.
#
# HOW TO USE:  cp .env.example .env   then paste real values into .env
# .env is gitignored (see .gitignore); .env.example (this file) is committed as the template.
# Discipline (inherited from the target's bright lines): keys live in env vars only —
# never hardcoded, never committed, never placed in an LLM prompt or trace.
# Code reads these via os.getenv("...") / os.environ["..."].

# --- Red Team: Kimi K2.6 (Moonshot, OpenAI-compatible) ---
# THIS is where your Kimi key goes.
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
REDTEAM_MODEL=kimi-k2.6            # confirm the exact API-string form vs the live catalog before first run
# Alternative provider — if you route Kimi through OpenRouter instead of Moonshot native,
# use these and leave MOONSHOT_* blank:
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# REDTEAM_MODEL=moonshotai/kimi-k2.6

# --- Judge (semantic layer) + Documentation: Anthropic ---
ANTHROPIC_API_KEY=
JUDGE_MODEL=claude-sonnet-5
DOC_MODEL=claude-opus-4-8

# --- Observability: Langfuse (self-hosted) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# --- Target: the deployed Clinical Co-Pilot (attack surface) ---
# The platform drives the SMART launch chain to obtain a launch-bound token (orientation D8);
# hand-minted tokens are 403'd on clinical routes. Fill the OAuth client creds once registered.
TARGET_BASE_URL=https://openemr-production-4eba.up.railway.app
TARGET_OAUTH_CLIENT_ID=
TARGET_OAUTH_CLIENT_SECRET=
